{
  "name": "basque-xiii",
  "version": "1.0.0",
  "description": "Site web du club de rugby Basque XIII",
  "scripts": {
    "build": "npm run css:build && node build.js",
    "css:build": "tailwindcss -i ./css/input.css -o ./css/output.css --minify",
    "css:watch": "tailwindcss -i ./css/input.css -o ./css/output.css --watch",
    "dev": "concurrently \"npm run css:watch\" \"npm run css:build && node build.js\""
  },
  "keywords": [
    "rugby",
    "basque",
    "xiii"
  ],
  "author": "Maxime COURTIAU",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
